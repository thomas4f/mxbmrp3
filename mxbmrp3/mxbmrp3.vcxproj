  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.targets" />
  <ImportGroup Label="ExtensionTargets">
  </ImportGroup>
  <!-- Auto-stamp the 4th version component (BUILD) from the git commit count into a
       git-ignored generated header (version_build.g.h), before every compile. So
       MAJOR/MINOR/PATCH stay manual in resource.h and the build number is never edited
       by hand. WriteOnlyWhenDifferent avoids needless rebuilds when the count is
       unchanged; a git failure falls back to 0 so the build always succeeds. -->
  <Target Name="StampVersion" BeforeTargets="ClCompile;ResourceCompile">
    <Exec Command="git -C &quot;$(MSBuildProjectDirectory)&quot; rev-list --count HEAD"
          ConsoleToMSBuild="true" ContinueOnError="true" StandardOutputImportance="low">
      <Output TaskParameter="ConsoleOutput" PropertyName="GitCommitCount" />
    </Exec>
    <PropertyGroup>
      <VerBuildAuto Condition="'$(GitCommitCount)' != ''">$(GitCommitCount.Trim())</VerBuildAuto>
      <VerBuildAuto Condition="'$(GitCommitCount)' == ''">0</VerBuildAuto>
    </PropertyGroup>
    <WriteLinesToFile File="$(MSBuildProjectDirectory)\version_build.g.h"
                      Lines="#pragma once;#define VER_BUILD_AUTO $(VerBuildAuto)"
                      Overwrite="true" WriteOnlyWhenDifferent="true" />
  </Target>
</Project>
