  <!-- Analytics keys injected from build-environment variables (consumed in
       core/plugin_constants.h). Applies to every configuration. Each define is added
       ONLY when its env var is set, so a plain developer build (vars unset) omits them
       and the code falls back to its placeholder (analytics disabled). Set
       APTABASE_KEY / GOATCOUNTER_TOKEN in the build environment for an official
       release (GOATCOUNTER_CODE is optional — it's public and hardcoded to "mxbmrp3"
       in plugin_constants.h; set it only to override the site code). Keys are
       alphanumeric/hyphen, so they pass through /D as-is. -->
  <ItemDefinitionGroup>
    <ClCompile>
      <PreprocessorDefinitions Condition="'$(APTABASE_KEY)'!=''">MXBMRP3_APTABASE_KEY=$(APTABASE_KEY);%(PreprocessorDefinitions)</PreprocessorDefinitions>
      <PreprocessorDefinitions Condition="'$(GOATCOUNTER_CODE)'!=''">MXBMRP3_GOATCOUNTER_CODE=$(GOATCOUNTER_CODE);%(PreprocessorDefinitions)</PreprocessorDefinitions>
      <PreprocessorDefinitions Condition="'$(GOATCOUNTER_TOKEN)'!=''">MXBMRP3_GOATCOUNTER_TOKEN=$(GOATCOUNTER_TOKEN);%(PreprocessorDefinitions)</PreprocessorDefinitions>
    </ClCompile>
  </ItemDefinitionGroup>
